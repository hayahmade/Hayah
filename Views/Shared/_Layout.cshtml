public sealed record HayahJob(
    Guid Id,
    string Name,
    DateTimeOffset CreatedAt,
    string[] Tags);
public interface IHayahRunner
{
    Task<Result> RunAsync(HayahJob job, CancellationToken token);
}
private async Task<Result> RunInternalAsync(HayahJob job, CancellationToken token)
{
    using var scope = _scopeFactory.CreateScope();
    var handler = scope.ServiceProvider.GetRequiredService<IHayahHandler>();
    return await handler.HandleAsync(job, token);
}
