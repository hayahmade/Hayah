@{
    ViewData["Title"] = "Home";
    ViewData["SiteTitle"] = "Hayah";
}

<section id="about" class="section-padding hayah-section-alt hayah-below-logo">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 order-lg-2 order-1 hayah-hero-text-col">
                <p class="text-uppercase small fw-semibold mb-2 hayah-about-accent">FREELANCE DEVELOPMENT / CODING</p>
                <h2 class="h2 fw-bold mb-3 text-dark">
                    Building websites, apps and automations that deliver.
                </h2>
                <p class="text-secondary mb-4 hayah-about-intro">
                    Here at Hayah, we specialize in custom websites, mobile apps for Android and iOS, digital design and automation that maximizes efficiency, helps meet deadlines and minimizes errors. From concept to reality is our mission. We achieve this goal with the help of AI tools that speed up production and eliminate human oversight.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a href="#projects" class="btn btn-outline-primary btn-lg px-4 hayah-btn-secondary">View portfolio</a>
                    <a href="#contact" class="btn btn-primary btn-lg px-4 hayah-btn-primary"><span class="hayah-btn-label">Quote a project</span></a>
                </div>
                <img src="~/images/starting-at-99-neon.png"
                     alt="Starting at $99"
                     class="hayah-starting-price-badge" />
                <div class="d-flex flex-wrap align-items-center gap-4 text-secondary">
                    <div>
                        <div class="fw-semibold">Core stack</div>
                        <div>.NET · C# · ASP.NET Core · Python · SQL</div>
                    </div>
                    <div>
                        <div class="fw-semibold">Services</div>
                        <div>Websites · Android / iOS apps · Automation · APIs & integrations</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 mt-4 mt-lg-0 order-lg-1 order-2">
                <div class="hayah-content-box-wrap hayah-highlight-card">
                    <div class="hayah-content-box p-4 rounded-3">
<h3 class="hayah-highlight-title h5 fw-bold mb-3 text-center">Recent Project Highlights</h3>
                        <p class="mb-2 fw-semibold"><span class="hayah-project-title">FileXverter</span></p>
                        <p class="hayah-highlight-body text-secondary mb-3">
                            A production-ready file conversion and processing tool built with ASP.NET Core, designed for reliability and ease of deployment.
                        </p>
                        <ul class="hayah-highlight-body text-secondary mb-3">
                        <li>Robust backend with clean architecture</li>
                        <li>Configurable, documented deployment flow</li>
                        <li>Built for real-world usage and extension</li>
                    </ul>
                    <a href="https://filexverter.com" class="hayah-highlight-link" target="_blank" rel="noopener">Visit filexverter.com →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="services" class="section-padding">
    <div class="container">
        <h2 class="h3 fw-bold mb-4 text-center">SERVICES</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body hayah-services-website">
                        <h3 class="h5 fw-bold">Website building</h3>
                        <p class="text-secondary small mb-3">
                            Custom websites and web applications—from marketing sites to full-stack apps. Responsive, fast, and built to last.
                        </p>
                        <ul class="small text-secondary mb-0">
                            <li>Marketing and portfolio sites</li>
                            <li>Web apps and dashboards</li>
                            <li>API-driven frontends</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body hayah-services-website">
                        <h3 class="h5 fw-bold">Android & iOS apps</h3>
                        <p class="text-secondary small mb-3">
                            Native and cross-platform mobile apps for Android and iOS. From MVPs to production-ready releases.
                        </p>
                        <ul class="small text-secondary mb-0">
                            <li>Native and cross-platform development</li>
                            <li>UI/UX tailored to each platform</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body hayah-services-website">
                        <h3 class="h5 fw-bold">Automation & tools</h3>
                        <p class="text-secondary small mb-3">
                            Scripts, utilities, and programs that automate repetitive work—file processing, data pipelines, and task automation.
                        </p>
                        <ul class="small text-secondary mb-0">
                            <li>File and data processing</li>
                            <li>Workflow and task automation</li>
                            <li>Internal tools packaged for reuse</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body hayah-services-website">
                        <h3 class="h5 fw-bold">APIs & integrations</h3>
                        <p class="text-secondary small mb-3">
                            Backend APIs, third-party integrations, and services that connect your systems and data.
                        </p>
                        <ul class="small text-secondary mb-0">
                            <li>REST and API design</li>
                            <li>Third-party service integrations</li>
                            <li>Data sync and webhooks</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="projects" class="section-padding hayah-section-alt">
    <div class="container">
        <h2 class="h3 fw-bold mb-4 text-center">PROJECT PORTFOLIO</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h3 class="h5 fw-bold mb-2"><span class="hayah-project-title">NotForgotten</span></h3>
                        <p class="text-secondary small mb-3 flex-grow-1">
                            A mobile app project focused on connecting people experiencing homelessness with nearby resources, support,
                            and up‑to‑date information—optimized for slow connections and small screens.
                        </p>
                        <ul class="small text-secondary mb-3">
                            <li>Location‑aware access to shelters and services, only when users opt in</li>
                            <li>Simple, clear interface designed for outreach teams and real‑world use</li>
                            <li>Emergency / missing‑person flow with explicit, one‑time location consent</li>
                            <li>Built to be extendable as NotForgotten and partner services grow</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-secondary-subtle text-secondary-emphasis small">
                                Mobile design
                            </span>
                        </div>
                        <a href="https://hayahmade.github.io/NotForgotten/" class="small" target="_blank" rel="noopener">View project →</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h3 class="h5 fw-bold mb-2"><span class="hayah-project-title">InvoiceR</span></h3>
                        <p class="text-secondary small mb-3 flex-grow-1">
                            A simple, fast invoicing tool built for freelancers and small teams to create, track, and manage invoices without overhead.
                        </p>
                        <ul class="small text-secondary mb-3">
                            <li>Clean UI for line items, discounts, and tax</li>
                            <li>Persistent invoice history for repeat clients</li>
                            <li>Structured data ready for export or printing on demand</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-secondary-subtle text-secondary-emphasis small">
                                Ready for distribution
                            </span>
                            <span class="badge bg-secondary-subtle text-secondary-emphasis small">
                                Mobile app version soon
                            </span>
                        </div>
                        <button type="button" class="btn btn-outline-light btn-sm align-self-start hayah-screenshot-toggle" data-target="#invoicerScreens">
                            View example ↓
                        </button>
                        <div id="invoicerScreens" class="d-flex gap-2 mt-3 d-none">
                            <a href="~/images/InvoiceR-window.png" target="_blank" class="flex-fill">
                                <img src="~/images/InvoiceR-window.png" alt="InvoiceR main window" class="img-fluid rounded-2 shadow-sm">
                            </a>
                            <a href="~/images/InvoiceR-invoicesample.png" target="_blank" class="flex-fill">
                                <img src="~/images/InvoiceR-invoicesample.png" alt="InvoiceR generated invoice sample" class="img-fluid rounded-2 shadow-sm">
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h3 class="h5 fw-bold mb-2"><span class="hayah-project-title">Budget Buster</span></h3>
                        <p class="text-secondary small mb-3 flex-grow-1">
                            An interactive fiscal health explorer for governmental structures, visualizing budgets, revenue, and debt across multiple levels—federal, state, county, and settlement—using sample data.
                        </p>
                        <ul class="small text-secondary mb-3">
                            <li>Drill‑down views from federal rollups to individual settlements</li>
                            <li>Key metrics like surplus, revenue per capita, and debt service surfaced at a glance</li>
                            <li>Responsive, print‑friendly UI built for presenting complex data clearly</li>
                        </ul>
                        <span class="badge bg-secondary-subtle text-secondary-emphasis small align-self-start mb-2">
                            Concept / prototype
                        </span>
                        <a href="https://hayahmade.github.io/budget-buster/" class="small mt-auto" target="_blank" rel="noopener">View project →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="section-padding">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h2 class="h3 fw-bold mb-3">LET'S START A PROJECT</h2>
                <p class="text-secondary mb-3">
                    Ready to start something, or just exploring what’s possible? Send a brief description of your project, budget, deadline and any existing systems you’d like to integrate with.
                </p>
                <p class="text-secondary mb-0">
                    I typically respond within 24hrs.
                </p>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="hayah-content-box-wrap">
                    <div class="hayah-content-box p-4 rounded-3">
                        <p class="text-secondary mb-4">
                            Click the button below to open your email app and send a message.
                        </p>
                        <a href="mailto:itszakarayas@proton.me?subject=Hayah%20project%20inquiry" class="btn btn-primary w-100 hayah-btn-primary text-decoration-none"><span class="hayah-btn-label">Send message</span></a>
                        <p class="small text-secondary mt-2 mb-0">
                            Opens your default email app to send a message.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


